{
  "$schema": "claude-plugin-v1",
  "name": "qa-tooling",
  "displayName": "QA Tooling",
  "version": "0.1.2",
  "description": "QA/QC workflow automation for web projects: auto-detect stack, generate qa-profile.json for the QA Annotator extension, and sync QA reports into Jira via MCP.",
  "author": {
    "name": "OMH Co"
  },
  "license": "MIT",
  "keywords": ["qa", "qc", "jira", "figma", "astro", "annotator"],

  "requirements": {
    "claudeCode": ">=1.0.0",
    "mcps": {
      "required": [],
      "recommended": [
        "mcp-atlassian",
        "figma",
        "chrome-devtools"
      ]
    }
  },

  "config": {
    "defaultProfilePath": "docs/qa/qa-profile.json",
    "defaultFigmaTreePath": "docs/qa/qa-figma-tree.json",
    "defaultReportsDir": "docs/qa/reports",
    "defaultDocsDir": "docs/qa",
    "schemaVersion": "qa-profile-v1",
    "figmaTreeSchemaVersion": "qa-figma-tree-v1"
  }
}
