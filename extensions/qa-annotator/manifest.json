{
  "manifest_version": 3,
  "name": "QA Annotator",
  "short_name": "QA Annotator",
  "version": "0.6.0",
  "description": "Click any element on any website to log QA/QC issues. Project-aware via Profiles. Exports JSON/Markdown/ZIP for Claude + Jira sync.",

  "minimum_chrome_version": "114",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "tabs",
    "clipboardRead"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "QA Annotator",
    "default_icon": {
      "16":  "assets/extension_icon16.png",
      "32":  "assets/extension_icon32.png",
      "48":  "assets/extension_icon48.png",
      "128": "assets/extension_icon128.png"
    }
  },

  "icons": {
    "16":  "assets/extension_icon16.png",
    "32":  "assets/extension_icon32.png",
    "48":  "assets/extension_icon48.png",
    "128": "assets/extension_icon128.png"
  },

  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://chrome.google.com/*",
        "*://chromewebstore.google.com/*",
        "*://accounts.google.com/*"
      ],
      "js": [
        "src/lib/glob-match.js",
        "src/lib/locale-detector.js",
        "src/lib/viewport-detector.js",
        "src/lib/figma-matcher.js",
        "src/lib/messages.js",
        "src/content/runtime-bridge.js",
        "src/vendor/axe.min.js",
        "src/lib/a11y-scan.js",
        "src/core/unique-selector.js",
        "src/core/computed-styles.js",
        "src/core/id-generator.js",
        "src/adapters/adapter-generic.js",
        "src/adapters/adapter-astro.js",
        "src/adapters/adapter-registry.js",
        "src/core/issue-builder.js",
        "src/core/inspector.js",
        "src/core/region-selector.js",
        "src/core/annotation-editor.js",
        "src/core/form-config.js",
        "src/core/panel-registry.js",
        "src/core/panels/pin-notes.js",
        "src/core/panels/runtime-context.js",
        "src/core/panels/design-fidelity.js",
        "src/core/panels/app-state.js",
        "src/core/panels/a11y-findings.js",
        "src/core/panels/i18n-findings.js",
        "src/core/form-modal.js",
        "src/core/screenshot.js",
        "src/content/overlay.js",
        "src/content/content.js"
      ],
      "css": ["src/content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "options_page": "src/settings/settings.html",

  "web_accessible_resources": [
    {
      "resources": [
        "src/profile/built-in/*.json",
        "src/lib/runtime-buffer.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
